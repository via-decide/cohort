{
  "name": "alchemist-remotion",
  "version": "1.0.0",
  "description": "Remotion project that renders branching documentary episodes from production.json",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "build": "remotion bundle src/index.ts",
    "validate": "ts-node --esm scripts/validate-production.ts",
    "render": "ts-node --esm render.ts",
    "render:all": "ts-node --esm render.ts --all",
    "render:list": "ts-node --esm render.ts --list"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "type": "module"
}
