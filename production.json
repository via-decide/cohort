{
  "version": "1.0",
  "studio": {
    "name": "cohert-media-merge",
    "mode": "audio-video-composer"
  },
  "production": {
    "id": "merge-001",
    "title": "Module 01 Final Merge",
    "slug": "module-01-final-merge",
    "status": "draft"
  },
  "inputs": {
    "videos": [
      {
        "id": "video-main",
        "path": "./assets/video/module-01.mp4",
        "startMs": 0,
        "endMs": null,
        "trimStartMs": 0,
        "trimEndMs": null,
        "volume": 1.0,
        "playbackRate": 1.0
      }
    ],
    "audios": [
      {
        "id": "audio-main",
        "path": "./assets/audio/module-01.wav",
        "startMs": 0,
        "endMs": null,
        "trimStartMs": 0,
        "trimEndMs": null,
        "volume": 1.0,
        "playbackRate": 1.0,
        "isCanonical": true
      }
    ]
  },
  "timeline": {
    "durationMs": null,
    "backgroundColor": "#000000",
    "tracks": [
      {
        "id": "track-video-1",
        "type": "video",
        "assetId": "video-main",
        "layer": 1,
        "startMs": 0
      },
      {
        "id": "track-audio-1",
        "type": "audio",
        "assetId": "audio-main",
        "layer": 2,
        "startMs": 0
      }
    ]
  },
  "sync": {
    "mode": "audio-led",
    "primaryAudioAssetId": "audio-main",
    "autoFitVideoToAudio": true,
    "allowVideoLoop": false,
    "allowAudioTrim": true
  },
  "output": {
    "format": "mp4",
    "videoCodec": "h264",
    "audioCodec": "aac",
    "fps": 30,
    "width": 1920,
    "height": 1080,
    "outputPath": "./renders/module-01-final.mp4"
  },
  "validation": {
    "requireVideo": true,
    "requireAudio": true,
    "requireCanonicalAudio": true,
    "rejectMissingFiles": true
  }
}
